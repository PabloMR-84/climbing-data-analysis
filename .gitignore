# --- Environment ---
.venv/
venv/
env/

# --- Data & Figures (Professional approach) ---
# Ignore absolutely everything inside the data folder
data/*

# EXCEPTION: Do not ignore subdirectories inside data (to maintain structure)
!data/**/

# EXCEPTION: Explicitly allow .gitkeep files
!data/**/.gitkeep

# --- Global File Extensions (Safety net) ---
# Prevent accidental uploads of data or media files anywhere in the project
*.csv
*.png
*.jpg
*.jpeg
*.xlsx

# --- Python / Jupyter ---
__pycache__/
*.pyc
.ipynb_checkpoints/
TEST.ipynb
eda_test.ipynb
data_discovery_backup.ipynb

# --- System / IDE ---
.vscode/
.DS_Store
*.log

# --- Personal Notes ---
instrucciones.txt
README_plantilla.md

